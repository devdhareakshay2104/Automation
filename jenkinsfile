pipeline {
    agent any

    environment {
        SERVER_IP = "ec2-3-239-116-255.compute-1.amazonaws.com"
        DEPLOY_PATH = "/var/www/html"
        PEM_FILE = "my-key.pem"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Files') {
            steps {
                sh '''
                pwd
                ls -ltr
                '''
            }
        }

        stage('Deploy Website') {
            steps {
                sh """
                chmod 400 ${PEM_FILE}

                scp -i ${PEM_FILE} -o StrictHostKeyChecking=no index.html ubuntu@${SERVER_IP}:/tmp/

                ssh -i ${PEM_FILE} -o StrictHostKeyChecking=no ubuntu@${SERVER_IP} << EOF

                sudo apt update -y
                sudo apt install nginx -y

                sudo mv /tmp/index.html ${DEPLOY_PATH}/index.html
                sudo chown www-data:www-data ${DEPLOY_PATH}/index.html
                sudo chmod 644 ${DEPLOY_PATH}/index.html

                sudo systemctl enable nginx
                sudo systemctl restart nginx

                EOF
                """
            }
        }
    }

    post {
        success {
            echo "Deployment Successful!"
        }

        failure {
            echo "Deployment Failed!"
        }
    }
}