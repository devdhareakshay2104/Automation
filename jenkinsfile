pipeline {
    agent any

    environment {
        EC2_HOST = "ec2-3-239-116-255.compute-1.amazonaws.com"
    }

    stages {

        stage('Checkout') {
            steps {
                echo "Checking out source code..."
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo "Creating index.html..."

                writeFile file: 'index.html', text: '''
<!-- Paste your complete HTML code here -->
'''
            }
        }

        stage('Deploy to EC2') {
            steps {
                echo "Deploying website to EC2..."

                sshagent(['ec2-key']) {

                    sh """
                    scp -o StrictHostKeyChecking=no index.html ubuntu@${EC2_HOST}:/tmp/

                    ssh -o StrictHostKeyChecking=no ubuntu@${EC2_HOST} << EOF

                    if ! command -v nginx >/dev/null 2>&1; then
                        sudo apt update -y
                        sudo apt install nginx -y
                    fi

                    sudo rm -f /var/www/html/index.nginx-debian.html
                    sudo cp /tmp/index.html /var/www/html/index.html
                    sudo chmod 644 /var/www/html/index.html

                    sudo systemctl enable nginx
                    sudo systemctl restart nginx
                    sudo systemctl status nginx --no-pager

                    EOF
                    """
                }
            }
        }
    }

    post {

        success {
            echo "Website deployed successfully."
            echo "Open: http://${EC2_HOST}"
        }

        failure {
            echo "Deployment Failed!"
        }

        always {
            cleanWs()
        }
    }
}